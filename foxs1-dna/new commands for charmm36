gmx pdb2gmx -f foxs1-mutant-dna.pdb -o processed_wt.gro -p topol.top -i posre.itp -ff charmm36-jul2022 -water tip3p -ignh -ter


gmx editconf -f processed_wt.gro -o boxed_wt.gro -c -d 1.2 -bt dodecahedron



gmx solvate -cp boxed_wt.gro -cs spc216.gro -o solvated_wt.gro -p topol.top  


gmx grompp -f ions.mdp -c solvated_wt.gro -p topol.top -o ions.tpr -maxwarn 1


gmx genion -s ions.tpr -o solvated_ions.gro -p topol.top -pname NA -nname CL -neutral -conc 0.15


gmx grompp -f em.mdp -c solvated_ions.gro -p topol.top -o em.tpr


gmx mdrun -v -deffnm em


gmx make_ndx -f em.gro -o index.ndx

create necessary groups


gmx genrestr -f em.gro -n index.ndx -o posre_DNA_D.itp -fc 1000 1000 1000


gmx genrestr -f em.gro -n index.ndx -o posre_DNA_C.itp -fc 1000 1000 1000


gmx genrestr -f em.gro -n index.ndx -o posre_Protein_chain_P.itp -fc 1000 1000 1000


gmx grompp -f nvt.mdp -c em.gro -r em.gro -p topol.top -n index.ndx -o nvt.tpr


gmx mdrun -v -deffnm nvt


gmx grompp -f npt.mdp -c nvt.gro -t nvt.cpt -r nvt.gro -p topol.top -n index.ndx -o npt.tpr


gmx mdrun -v -deffnm npt


gmx grompp -f md.mdp -c npt.gro -t npt.cpt -p topol.top -n index.ndx -o md_0_300.tpr


create new screen in tmux

gmx mdrun -v -deffnm md_0_300 -pin on -nb gpu -pme gpu -bonded gpu -update gpu




















